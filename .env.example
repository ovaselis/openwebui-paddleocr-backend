# API authentication
OCR_API_KEY=change-me

# OCR backend engine
# Options:
#   paddleocr - real OCR using PaddleOCR
#   mock      - test mode without real OCR
OCR_ENGINE=paddleocr

# OCR language hint.
# For mixed Latvian + English documents, keep this as lv together with the Latin recognition model below.
# Digital PDFs and DOCX files are extracted natively, so this mainly affects images/scanned PDFs.
OCR_LANG=lv

# OCR runtime device.
# Use cpu for safe default/server CPU deployment.
# Use gpu:0 when PaddlePaddle GPU is installed and supported.
OCR_DEVICE=cpu

# PaddleOCR model selection.
# Recommended for Latvian + English:
#   OCR_DETECTION_MODEL=PP-OCRv5_server_det
#   OCR_RECOGNITION_MODEL=latin_PP-OCRv5_mobile_rec
#
# Notes:
# - latin_PP-OCRv5_mobile_rec is better for mixed Latin-script languages than English-only recognition.
# - en_PP-OCRv5_mobile_rec can be used for English-only OCR.
OCR_DETECTION_MODEL=PP-OCRv5_server_det
OCR_RECOGNITION_MODEL=latin_PP-OCRv5_mobile_rec

# Upload and document limits
MAX_FILE_SIZE_MB=10
MAX_PDF_PAGES=3

# PDF rendering DPI for OCR fallback on scanned pages.
# 150 = faster, 200 = balanced, 300 = more accurate but slower/heavier.
PDF_DPI=200

# Hybrid PDF mode:
# true = use native PDF text extraction first, OCR only for scanned/tiny-text pages.
PDF_NATIVE_TEXT_FIRST=true
PDF_NATIVE_MIN_CHARS=80

# Logging
LOG_LEVEL=INFO
